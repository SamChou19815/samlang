  private function createMultiplePathsMaze(): Maze = {
    let grid = List.nil<int>()
      .cons(3)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(2)
