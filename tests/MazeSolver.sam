  private function testMultiplePathsAStar(): unit = {
    let maze = MazeSolver.createMultiplePathsMaze();
    let result = AStar.solve(maze);
    ForTests.assertBool(result.found, "Multiple paths A* should find path");
    ForTests.assertIntEquals(2, result.cost);
  }

  private function createZigZagMaze(): Maze = {
    let grid = List.nil<int>()
      .cons(3)
      .cons(-1)
      .cons(-1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(-1)
      .cons(1)
      .cons(-1)
      .cons(-1)
      .cons(1)
      .cons(-1)
      .cons(1)
      .cons(-1)
      .cons(-1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(-1)
      .cons(-1)
      .cons(-1)
      .cons(-1)
      .cons(1)
      .cons(2)
      .reverse();
    Maze.create(5, 5, grid)
  }

  private function testZigZagBFS(): unit = {
    let maze = MazeSolver.createZigZagMaze();
    let result = BFS.solve(maze);
    ForTests.assertBool(result.found, "Zigzag maze BFS should find path");
    ForTests.assertBool(Util.isGreaterThan(result.cost, 5), "Zigzag maze should have longer path");
  }

  private function testZigZagAStar(): unit = {
    let maze = MazeSolver.createZigZagMaze();
    let result = AStar.solve(maze);
    ForTests.assertBool(result.found, "Zigzag maze A* should find path");
    ForTests.assertBool(Util.isGreaterThan(result.cost, 5), "Zigzag maze should have longer path");
  }

  private function createAdjacentStartEndMaze(): Maze = {
    let grid = List.nil<int>().cons(2).cons(3).reverse();
    Maze.create(1, 2, grid)
  }

  private function testAdjacentStartEnd(): unit = {
    let maze = MazeSolver.createAdjacentStartEndMaze();
    let bfsResult = BFS.solve(maze);
    let dfsResult = DFS.solve(maze);
    let astarResult = AStar.solve(maze);
    let dijkstraResult = Dijkstra.solve(maze);
    ForTests.assertBool(bfsResult.found, "Adjacent BFS should find path");
    ForTests.assertBool(dfsResult.found, "Adjacent DFS should find path");
    ForTests.assertBool(astarResult.found, "Adjacent A* should find path");
    ForTests.assertBool(dijkstraResult.found, "Adjacent Dijkstra should find path");
    ForTests.assertIntEquals(1, bfsResult.cost);
    ForTests.assertIntEquals(1, astarResult.cost);
  }

  private function testAlgorithmConsistency(): unit = {
    let maze = MazeSolver.createComplexMaze();
    let bfsResult = BFS.solve(maze);
    let astarResult = AStar.solve(maze);
    ForTests.assertBool(bfsResult.found, "BFS should find path");
    ForTests.assertBool(astarResult.found, "A* should find path");
    ForTests.assertIntEquals(bfsResult.cost, astarResult.cost);
  }

  private function createSingleCellMaze(): Maze = {
    let grid = List.of(2);
    Maze.create(1, 1, grid)
  }

  private function testSingleCellMaze(): unit = {
    let maze = MazeSolver.createSingleCellMaze();
    let bfsResult = BFS.solve(maze);
    let dfsResult = DFS.solve(maze);
    let astarResult = AStar.solve(maze);
    let dijkstraResult = Dijkstra.solve(maze);
    ForTests.assertBool(!bfsResult.found, "Single cell with no end should not find path");
    ForTests.assertBool(!dfsResult.found, "Single cell DFS should not find path");
    ForTests.assertBool(!astarResult.found, "Single cell A* should not find path");
    ForTests.assertBool(!dijkstraResult.found, "Single cell Dijkstra should not find path");
  }

  private function testManhattanDistance(): unit = {
    let p1 = Position.init(0, 0);
    let p2 = Position.init(3, 4);
    ForTests.assertIntEquals(7, p1.manhattanDistance(p2));
    let p3 = Position.init(2, 2);
    ForTests.assertIntEquals(4, p1.manhattanDistance(p3));
  }

  private function testPositionEquality(): unit = {
    let p1 = Position.init(2, 3);
    let p2 = Position.init(2, 3);
    let p3 = Position.init(3, 2);
    ForTests.assertBool(p1.equals(p2), "Same positions should be equal");
    ForTests.assertBool(!p1.equals(p3), "Different positions should not be equal");
  }

  private function createLargeOpenMaze(): Maze = {
    let grid = List.nil<int>()
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(3)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(2)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .reverse();
    Maze.create(5, 6, grid)
  }

  private function testLargeOpenBFS(): unit = {
    let maze = MazeSolver.createLargeOpenMaze();
    let result = BFS.solve(maze);
    ForTests.assertBool(result.found, "Large open BFS should find path");
    ForTests.assertIntEquals(6, result.cost);
  }

  private function testLargeOpenAStar(): unit = {
    let maze = MazeSolver.createLargeOpenMaze();
    let result = AStar.solve(maze);
    ForTests.assertBool(result.found, "Large open A* should find path");
    ForTests.assertIntEquals(6, result.cost);
  }

  private function testLargeOpenDijkstra(): unit = {
    let maze = MazeSolver.createLargeOpenMaze();
    let result = Dijkstra.solve(maze);
    ForTests.assertBool(result.found, "Large open Dijkstra should find path");
    ForTests.assertIntEquals(6, result.cost);
  }

  private function testPathLength(): unit = {
    let maze = MazeSolver.createSimpleMaze();
    let result = BFS.solve(maze);
    ForTests.assertBool(result.found, "Should find path");
    let pathLength = result.path.length();
    ForTests.assertIntEquals(3, pathLength);
  }

  private function createSPiralMaze(): Maze = {
    let grid = List.nil<int>()
      .cons(2)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(-1)
      .cons(-1)
      .cons(-1)
      .cons(-1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(-1)
      .cons(1)
      .cons(1)
      .cons(-1)
      .cons(1)
      .cons(-1)
      .cons(1)
      .cons(1)
      .cons(-1)
      .cons(1)
      .cons(1)
      .cons(3)
      .reverse();
    Maze.create(5, 5, grid)
  }

  private function testSpiralMazeBFS(): unit = {
    let maze = MazeSolver.createSPiralMaze();
    let result = BFS.solve(maze);
    ForTests.assertBool(result.found, "Spiral maze BFS should find path");
    ForTests.assertBool(Util.isGreaterThan(result.cost, 10), "Spiral maze should have long path");
  }

  private function testSpiralMazeAStar(): unit = {
    let maze = MazeSolver.createSPiralMaze();
    let result = AStar.solve(maze);
    ForTests.assertBool(result.found, "Spiral maze A* should find path");
    ForTests.assertBool(Util.isGreaterThan(result.cost, 10), "Spiral maze should have long path");
  }

  private function createWeightedPathMaze(): Maze = {
    let grid = List.nil<int>()
      .cons(3)
      .cons(1)
      .cons(1)
      .cons(1)
      .cons(5)
      .cons(1)
      .cons(2)
      .cons(1)
      .cons(1)
      .reverse();
    Maze.create(3, 3, grid)
  }

  private function testWeightedPathDijkstra(): unit = {
    let maze = MazeSolver.createWeightedPathMaze();
    let result = Dijkstra.solve(maze);
    ForTests.assertBool(result.found, "Weighted maze Dijkstra should find path");
    ForTests.assertBool(
      Util.isLessThan(result.cost, 10),
      "Dijkstra should find cheaper path avoiding weight 5"
    );
  }

  function run(): unit = {
    MazeSolver.testSimpleMazeBFS();
    MazeSolver.testSimpleMazeDFS();
    MazeSolver.testSimpleMazeAStar();
    MazeSolver.testSimpleMazeDijkstra();
    MazeSolver.testNoSolutionBFS();
    MazeSolver.testNoSolutionDFS();
    MazeSolver.testNoSolutionAStar();
    MazeSolver.testNoSolutionDijkstra();
    MazeSolver.testComplexMazeBFS();
    MazeSolver.testComplexMazeAStar();
    MazeSolver.testComplexMazeDijkstra();
    MazeSolver.testTerrainCostBFS();
    MazeSolver.testTerrainCostDijkstra();
    MazeSolver.testLongCorridorBFS();
    MazeSolver.testLongCorridorDFS();
    MazeSolver.testLongCorridorAStar();
    MazeSolver.testLongCorridorDijkstra();
    MazeSolver.testOpenSpaceBFS();
    MazeSolver.testOpenSpaceAStar();
    MazeSolver.testMultiplePathsBFS();
    MazeSolver.testMultiplePathsAStar();
    MazeSolver.testZigZagBFS();
    MazeSolver.testZigZagAStar();
    MazeSolver.testAdjacentStartEnd();
    MazeSolver.testAlgorithmConsistency();
    MazeSolver.testSingleCellMaze();
    MazeSolver.testManhattanDistance();
    MazeSolver.testPositionEquality();
    MazeSolver.testLargeOpenBFS();
    MazeSolver.testLargeOpenAStar();
    MazeSolver.testLargeOpenDijkstra();
    MazeSolver.testPathLength();
    MazeSolver.testSpiralMazeBFS();
    MazeSolver.testSpiralMazeAStar();
    MazeSolver.testWeightedPathDijkstra();
  }
}
