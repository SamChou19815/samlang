import { ForTests } from tests.StdLib;

class ArithmeticTests {
  private function testAddition(): unit = {
    ForTests.assertIntEquals(5, 2 + 3);
    ForTests.assertIntEquals(0, 0 + 0);
    ForTests.assertIntEquals(0, 5 + -5);
    ForTests.assertIntEquals(-10, -3 + -7);
    ForTests.assertIntEquals(1000000, 500000 + 500000);
  }

  private function testSubtraction(): unit = {
    ForTests.assertIntEquals(2, 5 - 3);
    ForTests.assertIntEquals(0, 5 - 5);
    ForTests.assertIntEquals(-2, 3 - 5);
    ForTests.assertIntEquals(10, 5 - -5);
    ForTests.assertIntEquals(-10, -3 - 7);
  }

  private function testMultiplication(): unit = {
    ForTests.assertIntEquals(6, 2 * 3);
    ForTests.assertIntEquals(0, 0 * 5);
    ForTests.assertIntEquals(0, 5 * 0);
    ForTests.assertIntEquals(-15, 3 * -5);
    ForTests.assertIntEquals(15, -3 * -5);
    ForTests.assertIntEquals(1, 1 * 1);
  }

  private function testDivision(): unit = {
    ForTests.assertIntEquals(2, 6 / 3);
    ForTests.assertIntEquals(0, 2 / 5);
    ForTests.assertIntEquals(3, 10 / 3);
    ForTests.assertIntEquals(-2, -6 / 3);
    ForTests.assertIntEquals(2, -6 / -3);
    ForTests.assertIntEquals(-3, 10 / -3);
  }

  private function testModulo(): unit = {
    ForTests.assertIntEquals(0, 6 % 3);
    ForTests.assertIntEquals(2, 5 % 3);
    ForTests.assertIntEquals(1, 10 % 3);
    ForTests.assertIntEquals(0, 100 % 10);
    ForTests.assertIntEquals(7, 17 % 10);
  }

  private function testUnaryNegation(): unit = {
    ForTests.assertIntEquals(-5, -5);
    ForTests.assertIntEquals(5, 0 - -5);
    ForTests.assertIntEquals(0, -0);
    ForTests.assertIntEquals(-100, -100);
  }

  private function testPrecedence(): unit = {
    ForTests.assertIntEquals(14, 2 + 3 * 4);
    ForTests.assertIntEquals(20, (2 + 3) * 4);
    ForTests.assertIntEquals(5, 10 - 2 * 3 + 1);
    ForTests.assertIntEquals(5, 2 + 3 * 4 - 9);
  }

  private function testComplexExpressions(): unit = {
    ForTests.assertIntEquals(30, (1 + 2) * (3 + 4) * 2 - 12);
    ForTests.assertIntEquals(9, 100 / 10 - 5 + 4);
    ForTests.assertIntEquals(42, 6 * 7 + 7 - 7);
    ForTests.assertIntEquals(3, 1 + 2 * 3 / 2 - 1);
  }

  private function abs(n: int): int = if n < 0 { -n } else { n }

  private function testAbsFunction(): unit = {
    ForTests.assertIntEquals(5, ArithmeticTests.abs(5));
    ForTests.assertIntEquals(5, ArithmeticTests.abs(-5));
    ForTests.assertIntEquals(0, ArithmeticTests.abs(0));
    ForTests.assertIntEquals(100, ArithmeticTests.abs(-100));
  }

  private function sign(n: int): int = if n > 0 { 1 } else if n < 0 { -1 } else { 0 }

  private function testSignFunction(): unit = {
    ForTests.assertIntEquals(1, ArithmeticTests.sign(42));
    ForTests.assertIntEquals(-1, ArithmeticTests.sign(-42));
    ForTests.assertIntEquals(0, ArithmeticTests.sign(0));
  }

  private function testDivisionTruncation(): unit = {
    ForTests.assertIntEquals(0, 1 / 2);
    ForTests.assertIntEquals(0, 1 / 10);
    ForTests.assertIntEquals(1, 3 / 2);
    ForTests.assertIntEquals(2, 5 / 2);
    ForTests.assertIntEquals(-1, -3 / 2);
  }

  private function testModuloProperties(): unit = {
    let a = 17;
    let b = 5;
    let q = a / b;
    let r = a % b;
    ForTests.assertIntEquals(a, q * b + r);
    let c = 100;
    let d = 7;
    let q2 = c / d;
    let r2 = c % d;
    ForTests.assertIntEquals(c, q2 * d + r2);
  }

  function run(): unit = {
    ArithmeticTests.testAddition();
    ArithmeticTests.testSubtraction();
    ArithmeticTests.testMultiplication();
    ArithmeticTests.testDivision();
    ArithmeticTests.testModulo();
    ArithmeticTests.testUnaryNegation();
    ArithmeticTests.testPrecedence();
    ArithmeticTests.testComplexExpressions();
    ArithmeticTests.testAbsFunction();
    ArithmeticTests.testSignFunction();
    ArithmeticTests.testDivisionTruncation();
    ArithmeticTests.testModuloProperties();
  }
}
